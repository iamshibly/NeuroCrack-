# NeuroCrack — environment variable template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is already in .gitignore.

# ── OpenAI Auth ───────────────────────────────────────────────────────────────
# Required. Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Model tiers ───────────────────────────────────────────────────────────────
# Three slots let you control cost vs. quality independently.
# Lightweight — classifiers, fast cheap calls (keep at gpt-4o-mini)
OPENAI_MODEL_LIGHTWEIGHT=gpt-4o-mini
# Medium — most academic answers
OPENAI_MODEL_MEDIUM=gpt-4o-mini
# Strong — complex math, multi-part, long explanations
OPENAI_MODEL_STRONG=gpt-4o

# ── Token limits per tier (uncomment to override defaults) ───────────────────
# OPENAI_MAX_TOKENS_LIGHTWEIGHT=80
# OPENAI_MAX_TOKENS_MEDIUM=600
# OPENAI_MAX_TOKENS_STRONG=1200

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# ── Feature flags ─────────────────────────────────────────────────────────────
# Vision: set to "false" only if your model does not support image input
ENABLE_VISION=true
# Public retrieval (Wikipedia): off by default, enable for factual augmentation
ENABLE_PUBLIC_RETRIEVAL=false

# ── Debug overrides (development / testing only) ──────────────────────────────
# These are SAFE to leave unset in production — all default to disabled.
# Do NOT set these in a production .env file.

# Force all requests to use a specific model tier regardless of question type.
# Useful for cost testing or debugging a specific tier.
# Values: lightweight | medium | strong  (unset = normal routing)
# DEBUG_FORCE_TIER=lightweight

# Skip chapter and Wikipedia retrieval entirely.
# Useful when testing answer quality without evidence augmentation.
# DEBUG_DISABLE_RETRIEVAL=true

# Treat every request as if no image was attached (ignores any uploaded image).
# Useful for testing text-only paths when ENABLE_VISION=true.
# DEBUG_DISABLE_VISION=true
